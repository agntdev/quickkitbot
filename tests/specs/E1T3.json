[
  {
    "name": "/echo with text echoes the text",
    "steps": [
      {
        "send": { "text": "/echo Hello world" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Hello world" } }
        ]
      }
    ]
  },
  {
    "name": "/echo without text prompts and echoes reply",
    "steps": [
      {
        "send": { "text": "/echo" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Please reply to this message with the text you want echoed." } }
        ]
      },
      {
        "send": {
          "update": {
            "update_id": 2,
            "message": {
              "message_id": 2,
              "date": 0,
              "chat": { "id": 1, "type": "private", "first_name": "Test" },
              "from": { "id": 1, "is_bot": false, "first_name": "Test" },
              "text": "test reply",
              "reply_to_message": {
                "message_id": 1001,
                "date": 0,
                "chat": { "id": 1, "type": "private", "first_name": "Test" },
                "from": { "id": 42, "is_bot": true, "first_name": "TestBot" },
                "text": "Please reply to this message with the text you want echoed."
              }
            }
          }
        },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "test reply" } }
        ]
      }
    ]
  }
]