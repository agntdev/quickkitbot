[
  {
    "name": "/start sends welcome with main menu",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Welcome! I am ready to help.",
              "reply_markup": {
                "inline_keyboard": [
                  [{ "text": "Help", "callback_data": "help" }]
                ]
              }
            }
          }
        ]
      }
    ]
  },
  {
    "name": "clicking Help in main menu shows help text",
    "steps": [
      {
        "send": { "callback_query": { "data": "help" } },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "sendMessage",
            "payload": {
              "text": "Available commands:\n/start — Start the bot\n/help — Show this help message"
            }
          }
        ]
      }
    ]
  }
]