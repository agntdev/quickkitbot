[
  {
    "name": "/start callback Help button shows help",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Welcome! I am ready to help." } }
        ]
      },
      {
        "send": { "callback": "help" },
        "expect": [
          { "method": "sendMessage", "payload": { "text": "Available commands:\n/start — Start the bot\n/help — Show this help message" } }
        ]
      }
    ]
  }
]